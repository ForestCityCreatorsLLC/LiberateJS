{
  "name": "standalone",
  "delete_paths": [
    "standalone",
    "node_modules/@standalone",
    "eject_standalone.py",
    "fetch_data.py",
    "src/lib/app-params.js"
  ],
  "dependencies_to_remove": ["standalone"],
  "scripts_to_remove": ["standalone"],
  "replace_terms": [
    { "pattern": "standalone", "replacement": "standalone" }
  ],
  "ast_rules": {
    "wrappers": ["StandaloneWrapper", "StandaloneWrapper"],
    "db_wrapper": "StandaloneDB",
    "db_replacement_import": "import { prisma } from '@/lib/prisma';",
    "db_replacement_path": "@/lib/prisma",
    "auth_wrapper": "StandaloneAuth",
    "auth_hook": "useStandaloneUser",
    "auth_replacement_nextjs": {
      "wrapper": "SessionProvider",
      "hook": "useSession",
      "import": "import { SessionProvider, useSession } from 'next-auth/react';",
      "path": "next-auth/react"
    },
    "auth_replacement_spa": {
      "wrapper": "AuthProvider",
      "hook": "useAuth",
      "import": "import { AuthProvider, useAuth } from '@/context/AuthContext';",
      "path": "@/context/AuthContext"
    }
  }
}
